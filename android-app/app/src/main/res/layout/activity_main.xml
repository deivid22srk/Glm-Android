<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="false">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@id/scroll_view">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            app:title="@string/app_name"
            app:subtitle="@string/proxy_stopped"
            app:titleTextColor="?attr/colorOnSurface"
            app:subtitleTextColor="?attr/colorOnSurfaceVariant" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="32dp">

            <!-- Status Card -->
            <com.google.android.material.card.MaterialCardView
                style="?attr/materialCardViewOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/status_dot"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/status_dot_red" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/status_label"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/status_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/proxy_stopped"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/loading_progress"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:visibility="gone"
                        android:indeterminateTint="?attr/colorPrimary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- URL Card (visible only when running) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/url_card"
                style="?attr/materialCardViewOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/url_label"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/url_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="17sp"
                        android:fontFamily="monospace"
                        android:textIsSelectable="true"
                        android:text="http://127.0.0.1:3005" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="18dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_copy_url"
                            style="?attr/materialButtonTonalStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/copy_url"
                            app:icon="@android:drawable/ic_menu_share"
                            app:iconGravity="textStart" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_open_browser"
                            style="?attr/materialButtonTonalStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="@string/open_in_browser"
                            app:icon="@android:drawable/ic_menu_view"
                            app:iconGravity="textStart" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Error Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/error_card"
                style="?attr/materialCardViewOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:strokeColor="?attr/colorError">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/error_label"
                        android:textColor="?attr/colorError"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/error_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="13sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logs Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/logs_card"
                style="?attr/materialCardViewOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/recent_logs"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"
                            android:textAllCaps="true" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_copy_logs"
                            style="?attr/borderlessButtonStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/copy_logs"
                            app:icon="@android:drawable/ic_menu_share"
                            app:iconGravity="textStart" />
                    </LinearLayout>

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="240dp"
                        android:layout_marginTop="8dp"
                        android:background="?attr/colorSurfaceContainerLow"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/logs_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textIsSelectable="true" />
                    </ScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Primary Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_toggle"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="@string/start_server"
                app:icon="@android:drawable/ic_media_play"
                app:iconGravity="textStart"
                app:cornerRadius="16dp" />

            <!-- Accounts Card (visible only when running) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/accounts_card"
                style="?attr/materialCardViewOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/accounts_label"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"
                            android:textAllCaps="true" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_refresh_accounts"
                            style="?attr/borderlessButtonStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/refresh"
                            app:icon="@android:drawable/ic_popup_sync"
                            app:iconGravity="textStart" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/accounts_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />

                    <TextView
                        android:id="@+id/accounts_empty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/no_accounts"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Login Google Button (opens OAuth flow in Chrome Custom Tab) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_login_google"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/login_google"
                app:icon="@android:drawable/ic_menu_my_calendar"
                app:iconGravity="textStart"
                app:cornerRadius="16dp" />

            <!-- View Captcha WebView Button (opens the captcha broker page
                 in a visible WebView so the user can inspect what the
                 background WebView is doing and solve interactive
                 challenges manually) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_captcha_webview"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/view_captcha_webview"
                app:icon="@android:drawable/ic_menu_view"
                app:iconGravity="textStart"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
