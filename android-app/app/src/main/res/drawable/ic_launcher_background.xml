<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon background — solid color matching the SVG's background
  (#0A0D10). The foreground layer carries all the visual content; this
  layer just ensures the launcher mask reveals a consistent color at
  the edges (circle/squircle/square/etc. depending on the launcher).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#0A0D10"
        android:pathData="M0,0h108v108h-108z" />
</vector>
