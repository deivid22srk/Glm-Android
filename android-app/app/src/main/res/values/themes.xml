<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
      Base theme derived from Material 3 (Material You).
      We use the Dark variant because the app is dark-only by design —
      the React panel served by the Go binary is dark-themed, and we
      want the native chrome to match.

      All Material 3 color roles are mapped explicitly so components
      like MaterialCardView, MaterialButton, and MaterialToolbar pick
      up the Blue tonal palette instead of falling back to M2 defaults.

      For dynamic color (Android 12+ wallpaper-derived palette), call
      DynamicColors.applyToActivityIfAvailable(activity) before
      setContentView in each activity — that overlays these tokens
      at runtime.
    -->
    <style name="Theme.GLMProxy" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/m3_primary</item>
        <item name="colorOnPrimary">@color/m3_on_primary</item>
        <item name="colorPrimaryContainer">@color/m3_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/m3_on_primary_container</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/m3_secondary</item>
        <item name="colorOnSecondary">@color/m3_on_secondary</item>
        <item name="colorSecondaryContainer">@color/m3_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/m3_on_secondary_container</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/m3_tertiary</item>
        <item name="colorOnTertiary">@color/m3_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/m3_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/m3_on_tertiary_container</item>

        <!-- Error -->
        <item name="colorError">@color/m3_error</item>
        <item name="colorOnError">@color/m3_on_error</item>
        <item name="colorErrorContainer">@color/m3_error_container</item>
        <item name="colorOnErrorContainer">@color/m3_on_error_container</item>

        <!-- Background & surface -->
        <item name="android:colorBackground">@color/m3_background</item>
        <item name="colorOnBackground">@color/m3_on_background</item>
        <item name="colorSurface">@color/m3_surface</item>
        <item name="colorOnSurface">@color/m3_on_surface</item>
        <item name="colorSurfaceVariant">@color/m3_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/m3_on_surface_variant</item>

        <!-- M3 surface container tones (1.14.0+) -->
        <item name="colorSurfaceContainerLow">@color/m3_surface_container_low</item>
        <item name="colorSurfaceContainer">@color/m3_surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/m3_surface_container_high</item>
        <item name="colorSurfaceContainerHighest">@color/m3_surface_container_highest</item>

        <!-- Outline -->
        <item name="colorOutline">@color/m3_outline</item>
        <item name="colorOutlineVariant">@color/m3_outline_variant</item>

        <!-- Status / nav bar (edge-to-edge draws behind them) -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Window background matches colorBackground for a seamless look -->
        <item name="android:windowBackground">@color/m3_background</item>
    </style>
</resources>
