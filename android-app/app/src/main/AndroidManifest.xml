<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network access: required so the embedded Go proxy can call
         the Z.ai / ZCode upstream APIs over the internet. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service: keeps the Go proxy alive when the user
         leaves the app, so OpenAI-compatible clients on the device
         can still reach 127.0.0.1:3005. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock: optional, prevents the device from sleeping while a
         long streaming chat completion is in flight. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Overlay permission for the invisible captcha WebView. The
         CaptchaWebViewManager attaches a 1x1 transparent WebView to
         the WindowManager so it keeps running JavaScript in background.
         TYPE_APPLICATION_OVERLAY requires this permission. If the user
         denies it, the manager falls back to TYPE_PRIVATE which doesn't
         need the permission but may be killed more aggressively. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Start-on-boot (plan 020, DIR-03): opt-in feature. Allows the
         BootReceiver to be invoked after device reboot so the proxy
         can restart itself if the user enabled the preference.
         The receiver is registered below with exported=false except
         for the BOOT_COMPLETED intent-filter (which the system uses). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GLMProxy"
        android:extractNativeLibs="true"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize|keyboardHidden|uiMode"
            android:label="@string/app_name"
            android:theme="@style/Theme.GLMProxy">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".ProxyService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Start-on-boot receiver (plan 020). exported=true is required
             for the system to deliver BOOT_COMPLETED; only the system can
             send that protected broadcast, so this is safe. -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
